# res.me Environment Variables
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://resme:password@localhost:5432/resme
POSTGRES_PASSWORD=password
POSTGRES_USER=resme
POSTGRES_DB=resme

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-min-32-characters-long-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage: local (dev) or s3 (production)
STORAGE_BACKEND=local
LOCAL_UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE_MB=10

# S3 (production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=resme-uploads
S3_ENDPOINT_URL=

# LLM (Gemini)
GEMINI_API_KEY=
DEFAULT_MODEL=gemini-2.0-flash
LLM_PROVIDER=gemini

# GitHub (optional, higher rate limits)
GITHUB_TOKEN=

# Hiring agent — clone https://github.com/interviewstreet/hiring-agent
HIRING_AGENT_PATH=./hiring-agent

# App URLs
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@res.me
